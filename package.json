{
  "name": "vibe-ai-partner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/core",
    "packages/shared",
    "packages/plugin-avatar/*",
    "packages/plugin-memory/*",
    "apps/*"
  ],
  "scripts": {
    "setup": "node apps/cli/dist/index.js setup",
    "start": "node apps/cli/dist/index.js start",
    "stop": "node apps/cli/dist/index.js stop",
    "restart": "npm stop && npm start",
    "status": "node apps/cli/dist/index.js status",
    "dev": "npm run dev -w apps/avatar-app",
    "build": "npm run build -ws",
    "test": "npm run test -ws",
    "tts:start": "cd apps/tts-server && uv run uvicorn vibe_tts.server:app --port 5111 --host 0.0.0.0",
    "tts:stop": "lsof -ti:5111 | xargs kill 2>/dev/null || echo 'TTS server not running'",
    "tts:install": "cd apps/tts-server && uv sync",
    "feeling": "node apps/cli/dist/index.js feeling",
    "action": "node apps/cli/dist/index.js action",
    "speak": "node apps/cli/dist/index.js speak"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
