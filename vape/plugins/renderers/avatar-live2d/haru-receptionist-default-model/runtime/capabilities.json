{
  "renderer": "live2d",
  "model": "haru_greeter_t05",
  "version": "1.0",

  "_note": "Introspection + alias contract for avatar_app. The renderer itself resolves feelings from model3.json FileReferences.Expressions (by Name) and actions from the SelfExpression motion group (by slot index); the paths here are informational. Feeling expressions authored 2026-07-06 from the model's own params; action motions mapped from the model's haru_g_mNN library by watching each arc.",

  "feelings": {
    "happy":      { "expression": "expressions/Happy.exp3.json" },
    "sad":        { "expression": "expressions/Sad.exp3.json" },
    "frustrated": { "expression": "expressions/Frustrated.exp3.json" },
    "curious":    { "expression": "expressions/Curious.exp3.json" },
    "proud":      { "expression": "expressions/Proud.exp3.json" },
    "anxious":    { "expression": "expressions/Anxious.exp3.json" },
    "excited":    { "expression": "expressions/Excited.exp3.json" },
    "calm":       { "expression": "expressions/Calm.exp3.json" },
    "bored":      { "expression": "expressions/Bored.exp3.json" },
    "angry":      { "expression": "expressions/Angry.exp3.json" },
    "blushing":   { "expression": "expressions/Blushing.exp3.json" },
    "surprised":  { "expression": "expressions/Surprised.exp3.json" },
    "content":    { "expression": "expressions/Content.exp3.json" },
    "shy":        { "expression": "expressions/Shy.exp3.json", "manualOnly": true }
  },

  "selfExpressions": {
    "nod":         { "motion": "motion/haru_g_m09.motion3.json", "group": "social" },
    "head_shake":  { "motion": "motion/haru_g_m11.motion3.json", "group": "social" },
    "head_tilt":   { "motion": "motion/haru_g_m25.motion3.json", "group": "reaction" },
    "laugh":       { "motion": "motion/haru_g_m04.motion3.json", "group": "emotional" },
    "giggle":      { "motion": "motion/haru_g_m06.motion3.json", "group": "emotional" },
    "gasp":        { "motion": "motion/haru_g_m24.motion3.json", "group": "reaction" },
    "think":       { "motion": "motion/haru_g_m20.motion3.json", "group": "reaction" },
    "celebrate":   { "motion": "motion/haru_g_m23.motion3.json", "group": "emotional" },
    "wave":        { "motion": "motion/haru_g_m12.motion3.json", "group": "social" },
    "bow":         { "motion": "motion/haru_g_m08.motion3.json", "group": "social" },
    "starry":      { "motion": "motion/haru_g_m21.motion3.json", "group": "emotional" },
    "clap":        { "motion": "motion/haru_g_m07.motion3.json", "group": "emotional" }
  },

  "lipSync": {
    "method": "rms",
    "parameter": "ParamMouthOpenY",
    "range": [0, 1]
  },

  "expressionAliases": {
    "celebrate": "celebrate",
    "cry": "cry",
    "sigh": null,
    "head_tilt": "head_tilt",
    "fist_pump": "starry",
    "tremble": null,
    "bounce": "giggle",
    "nod": "nod",
    "yawn": null,
    "facepalm": null,
    "puff_cheeks": null,
    "cover_face": null,
    "gasp": "gasp",
    "wave": "wave",
    "clap": "clap"
  }
}
