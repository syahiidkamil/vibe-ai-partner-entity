{
  "renderer": "live2d",
  "model": "haru_greeter_t05",
  "version": "1.0",

  "_note": "Introspection + alias contract for avatar_app. The renderer itself resolves feelings from model3.json FileReferences.Expressions (by Name) and actions from the SelfExpression motion group (by slot index); the paths here are informational. Feelings live in internal-feeling/ (by Name); actions in self-expression/ (by slot). nod/head_shake/head_tilt authored head-only 2026-07-06; the rest mapped from the haru_g_mNN library. shy is dial-recommended (auto), not manual-only.",

  "feelings": {
    "happy":      { "expression": "internal-feeling/Happy.exp3.json" },
    "sad":        { "expression": "internal-feeling/Sad.exp3.json" },
    "frustrated": { "expression": "internal-feeling/Frustrated.exp3.json" },
    "curious":    { "expression": "internal-feeling/Curious.exp3.json" },
    "proud":      { "expression": "internal-feeling/Proud.exp3.json" },
    "anxious":    { "expression": "internal-feeling/Anxious.exp3.json" },
    "excited":    { "expression": "internal-feeling/Excited.exp3.json" },
    "calm":       { "expression": "internal-feeling/Calm.exp3.json" },
    "bored":      { "expression": "internal-feeling/Bored.exp3.json" },
    "angry":      { "expression": "internal-feeling/Angry.exp3.json" },
    "blushing":   { "expression": "internal-feeling/Blushing.exp3.json" },
    "surprised":  { "expression": "internal-feeling/Surprised.exp3.json" },
    "content":    { "expression": "internal-feeling/Content.exp3.json" },
    "shy":        { "expression": "internal-feeling/Shy.exp3.json" }
  },

  "selfExpressions": {
    "nod":         { "motion": "self-expression/nod.motion3.json", "group": "social" },
    "head_shake":  { "motion": "self-expression/head_shake.motion3.json", "group": "social" },
    "head_tilt":   { "motion": "self-expression/head_tilt.motion3.json", "group": "reaction" },
    "laugh":       { "motion": "self-expression/laugh.motion3.json", "group": "emotional" },
    "giggle":      { "motion": "self-expression/giggle.motion3.json", "group": "emotional" },
    "gasp":        { "motion": "self-expression/gasp.motion3.json", "group": "reaction" },
    "think":       { "motion": "self-expression/think.motion3.json", "group": "reaction" },
    "celebrate":   { "motion": "self-expression/celebrate.motion3.json", "group": "emotional" },
    "wave":        { "motion": "self-expression/wave.motion3.json", "group": "social" },
    "bow":         { "motion": "self-expression/bow.motion3.json", "group": "social" },
    "starry":      { "motion": "self-expression/starry.motion3.json", "group": "emotional" },
    "clap":        { "motion": "self-expression/clap.motion3.json", "group": "emotional" }
  },

  "lipSync": {
    "method": "rms",
    "parameter": "ParamMouthOpenY",
    "range": [0, 1]
  },

  "expressionAliases": {
    "celebrate": "celebrate",
    "cry": "cry",
    "sigh": null,
    "head_tilt": "head_tilt",
    "fist_pump": "starry",
    "tremble": null,
    "bounce": "giggle",
    "nod": "nod",
    "yawn": null,
    "facepalm": null,
    "puff_cheeks": null,
    "cover_face": null,
    "gasp": "gasp",
    "wave": "wave",
    "clap": "clap"
  }
}
