# vape/.env.example — copy to `vape/.env` and fill in your values.
# `vape/.env` is gitignored (it holds secrets + per-machine config); this template is committed so
# the set of knobs is discoverable. Values below are placeholders / safe local defaults.

# --- Embeddings + vector DB (reserved for the future DB-accelerator phase; unused today) ---
# The June memory engine that read these was retired 2026-07-02; phase 3 ships as a new plugin.
GEMINI_API_KEY=your-gemini-api-key-here
MULTI_MODAL_EMBEDDING=gemini-embedding-2-preview
# Local Docker pgvector (container 'postgres_db', host 5433). Start via memory/ensure-db-tunnel.sh.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/postgres

# --- Diary staleness nudge (read by .claude/hooks/diary-reminder.sh) ---
# The time GAP in HOURS between the last diary entry and now, before the hook nudges Saori to write
# her diary. This is a TIME GAP, not a timezone offset. Default is 6 if unset. Lower it to be nudged
# sooner, raise it to be nudged less often. Resolution order: real env var > this vape/.env > default.
VAPE_DIARY_GAP_HOURS=6

# --- Diary gate at compaction (read by .claude/hooks/precompact-diary.sh) ---
# Compaction is BLOCKED once when the diary is stale, so Saori writes it in-session (with the living
# detail) before the window is summarized; run /compact again after and the gate opens.
# FRESH_MINUTES: how recently the newest diary entry must have been touched to count as fresh.
# BLOCK_COOLDOWN_MINUTES: escape hatch — after one block, any attempt within this window passes
# regardless (a blocked auto-compaction's retry passes the same way), so nobody is ever trapped.
VAPE_DIARY_FRESH_MINUTES=20
VAPE_DIARY_BLOCK_COOLDOWN_MINUTES=15
