{
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "50"
  },
  "permissions": {
    "allow": [
      "Bash(git log:*)",
      "Bash(lsof:*)",
      "Bash(mkdir:*)",
      "Bash(xargs ls:*)",
      "Bash(find:*)",
      "WebFetch(domain:www.anthropic.com)",
      "Bash(git remote:*)"
    ],
    "deny": [],
    "ask": [],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/temporal-ground.sh"
          }
        ]
      }
    ]
  },
  "enableAllProjectMcpServers": true
}
