{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "vape-avatar",
  "version": "0.1.0",
  "identifier": "com.vape.avatar",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5111"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
