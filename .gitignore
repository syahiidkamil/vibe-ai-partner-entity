# macOS Finder clutter
.DS_Store

# Models (downloaded by setup, not stored in git)
vape/model-stocks/live2d/
vape/model-stocks/vrm/
vape/model-stocks/threejs/
!vape/model-stocks/README.md

# Environment
.env
.env.local

# Build output (avatar plugins build during setup)
dist/
*.tsbuildinfo

# Proprietary SDK (not distributed in git)
**/live2dcubismcore.min.js

# Dependencies
node_modules/

# Python build artifacts
*.egg-info/
__pycache__/
*.pyc
.venv/

# Tauri build artifacts
**/src-tauri/target/
**/src-tauri/gen/

# Runtime
.tts-server.pid
.avatar-app.pid
.claude/scheduled_tasks.lock

# Generated interface (rebuilt at startup)
vape/engine/apps/avatar/interface.json

# Entity state (changes at runtime)
vape/entity/state/current.json

# User config (created by `vape setup`, varies per machine)
config.json

# Tracked intentionally despite the global ignore of **/.claude/settings.local.json
!.claude/settings.local.json

# backup-chat hook cursor (per-machine state)
.claude/hooks/.chat_id_tracker.txt
