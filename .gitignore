# macOS Finder clutter
.DS_Store

# Models (downloaded by setup, not stored in git)
vape/model-stocks/live2d/
vape/model-stocks/vrm/
vape/model-stocks/threejs/
!vape/model-stocks/README.md
vape/plugins/renderers/avatar-live2d/models

# Live2D editor sources (PSD/cmo3/can3) — not needed at runtime, keep the repo lean
vape/plugins/renderers/avatar-live2d/**/*.psd
vape/plugins/renderers/avatar-live2d/**/*.cmo3
vape/plugins/renderers/avatar-live2d/**/*.can3

# Environment — a bare pattern matches .env at ANY depth (nested folders included)
.env
.env.*
!.env.example
!.env.sample

# Memory subsystem — personal/machine-local infra (references the private tunnel)
vape/entity/memory/ensure-db-tunnel.sh

# Build output (avatar plugins build during setup)
dist/
*.tsbuildinfo

# Proprietary SDK (not distributed in git)
**/live2dcubismcore.min.js

# Dependencies
node_modules/

# Python build artifacts
*.egg-info/
__pycache__/
*.pyc
.venv/

# Tauri build artifacts
**/src-tauri/target/
**/src-tauri/gen/

# Runtime
.tts-server.pid
.avatar-app.pid
.claude/scheduled_tasks.lock

# Generated interface (rebuilt at startup)
vape/engine/apps/avatar/interface.json

# Entity state (changes at runtime)
vape/entity/state/current.json

# User config (created by `vape setup`, varies per machine)
config.json

# Tracked intentionally despite the global ignore of **/.claude/settings.local.json
!.claude/settings.local.json

# backup-chat hook cursor (per-machine state)
.claude/hooks/.chat_id_tracker.txt

# diary hook state (per-machine, ephemeral): compaction "owed" flag + staleness-nudge cooldown
# + the gate's block-once marker (mtime = when the last block fired; the escape-hatch clock)
.claude/hooks/.diary_pending
.claude/hooks/.diary_nudge_at
.claude/hooks/.diary_block_at

# dream hook state (per-machine): the gate-2 cursor — mtime = when the last dream finished.
# (The ratification alarm needs no state file: memory/proposals/pending/ IS its state.)
.claude/hooks/.dream_cursor

# Raw chat archive — auto-generated, high-churn, verbatim. The local staging
# buffer that feeds distillation; the durable memory is the diary (git), not this.
# (/* not /: a parent dir excluded whole can't have children re-included.)
vape/entity/storage/*
# Curated sources kept whole are memory, not churn — they ship:
!vape/entity/storage/raw_important_materials/
# ...but oversized keeps (video, big dumps) stay local:
vape/entity/storage/big_size_raw_important_materials/

misc/browser-profile
.playwright-mcp

# VRM models are the user's own (VRoid Hub licenses usually forbid
# redistribution) — keep them local; only the folder's README ships.
vape/plugins/renderers/avatar-vrm/vrm-models/*
!vape/plugins/renderers/avatar-vrm/vrm-models/README.md

misc/gitignored
vape/environment_files/

# Antigravity bridge runtime residue (markers + per-conversation cursors)
.agents/hooks/.agy_*
