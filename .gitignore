# macOS Finder clutter
.DS_Store

# Models (downloaded by setup, not stored in git)
vape/model-stocks/live2d/
vape/model-stocks/vrm/
vape/model-stocks/threejs/
!vape/model-stocks/README.md

# Environment — a bare pattern matches .env at ANY depth (nested folders included)
.env
.env.*
!.env.example
!.env.sample

# Memory subsystem — personal/machine-local infra (references the private tunnel)
vape/entity/memory/ensure-db-tunnel.sh

# Build output (avatar plugins build during setup)
dist/
*.tsbuildinfo

# Proprietary SDK (not distributed in git)
**/live2dcubismcore.min.js

# Dependencies
node_modules/

# Python build artifacts
*.egg-info/
__pycache__/
*.pyc
.venv/

# Tauri build artifacts
**/src-tauri/target/
**/src-tauri/gen/

# Runtime
.tts-server.pid
.avatar-app.pid
.claude/scheduled_tasks.lock

# Generated interface (rebuilt at startup)
vape/engine/apps/avatar/interface.json

# Entity state (changes at runtime)
vape/entity/state/current.json

# User config (created by `vape setup`, varies per machine)
config.json

# Tracked intentionally despite the global ignore of **/.claude/settings.local.json
!.claude/settings.local.json

# backup-chat hook cursor (per-machine state)
.claude/hooks/.chat_id_tracker.txt

# diary hook state (per-machine, ephemeral): compaction "owed" flag + staleness-nudge cooldown
.claude/hooks/.diary_pending
.claude/hooks/.diary_nudge_at

# dream hook state (per-machine): the gate-2 cursor — mtime = when the last dream finished
.claude/hooks/.dream_cursor

# Raw chat archive — auto-generated, high-churn, verbatim. The local staging
# buffer that feeds distillation; the durable memory is the diary (git), not this.
vape/entity/storage/

# Memory engine — churny runtime state (per-machine, high-churn). The durable,
# identity-adjacent memory (HOT.md, soul.json, MEMORY.md, reveries.json, the
# active_bubble register) stays TRACKED and diffable; only the live buffers below
# are ignored: the spike-store, the dream cursor, and the light-dream breadcrumb.
vape/entity/memory_wiki/bookmarks.jsonl
vape/entity/memory_wiki/dream_state.json
vape/entity/memory_wiki/last_thread.md

misc/browser-profile